{
  "name": "book-management-api",
  "version": "1.0.0",
  "description": "RESTful API for managing books with TypeScript, Express, and MongoDB",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "TS_NODE_PROJECT=tsconfig.test.json mocha --require ts-node/register 'test/**/*.test.ts' --exit",
    "test:unit": "TS_NODE_PROJECT=tsconfig.test.json mocha --require ts-node/register 'test/unit/**/*.test.ts' --exit",
    "test:api": "TS_NODE_PROJECT=tsconfig.test.json mocha --require ts-node/register 'test/*.test.ts' --exit",
    "test:coverage": "nyc npm test",
    "lint": "eslint src/**/*.ts",
    "seed": "ts-node src/scripts/seed.ts"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "mongodb",
    "mongoose",
    "jwt",
    "rest-api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-validator": "^7.0.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^4.3.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.25",
    "@types/sinon": "^17.0.3",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "chai": "^4.4.1",
    "eslint": "^8.57.0",
    "mocha": "^10.3.0",
    "mongodb-memory-server": "^9.1.6",
    "nyc": "^15.1.0",
    "sinon": "^17.0.1",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
